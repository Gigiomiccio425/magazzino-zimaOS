# Copia questo file in ".env" e modifica i valori.
# cp .env.example .env

# Password unica per accedere all'app (OBBLIGATORIO cambiarla)
APP_PASSWORD=cambiami

# Nome mostrato in alto a sinistra
APP_NAME=MAGAZZINO

# Chiave firma cookie di sessione. Lascia vuoto = generata e salvata in ./data/.secret_key
# Per generarne una: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Fuso orario
TZ=Europe/Rome
